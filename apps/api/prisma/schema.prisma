generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// EXISTING MODELS (with minimal additions)
// ============================================

model Organization {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique @db.VarChar(100)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  auditLogs          AuditLog[]          @relation("OrganizationAuditLogs")
  invitations        Invitation[]
  memberships        Membership[]
  
  // NEW RELATIONS
  platformConnections PlatformConnection[]
  adAccounts           AdAccount[]
  campaigns            Campaign[]
  adSets               AdSet[]
  ads                  Ad[]
  creatives            Creative[]
  creativeAssets       CreativeAsset[]
  apiKeys              ApiKey[]
}

model User {
  id                     String       @id @default(cuid())
  email                  String       @unique @db.VarChar(254)
  passwordHash           String
  firstName              String
  lastName               String
  status                 UserStatus   @default(ACTIVE)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  refreshTokenHash       String?
  avatarUrl              String?
  bio                    String?
  emailVerifiedAt        DateTime?
  jobTitle               String?
  language               String?      @default("en") @db.VarChar(10)
  lastLoginAt            DateTime?
  passwordResetExpiresAt DateTime?
  passwordResetTokenHash String?
  phone                  String?
  timezone               String?      @default("UTC") @db.VarChar(50)
  auditLogs              AuditLog[]   @relation("UserAuditLogs")
  createdInvitations     Invitation[] @relation("InvitationCreator")
  memberships            Membership[]
  
  // NEW RELATIONS
  createdPlatformConnections PlatformConnection[] @relation("PlatformConnectionCreator")
  apiKeys                     ApiKey[]
}

model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole @default(MEMBER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([organizationId, role])
}

model Invitation {
  id              String           @id @default(cuid())
  organizationId  String
  email           String           @db.VarChar(254)
  role            MembershipRole   @default(MEMBER)
  status          InvitationStatus @default(PENDING)
  tokenHash       String           @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdByUserId String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser   User             @relation("InvitationCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([organizationId, email, status])
  @@index([organizationId, expiresAt])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  actorId        String
  action         AuditAction
  entity         AuditEntity
  entityId       String?
  metadata       Json?
  ipAddress      String?      @db.VarChar(45)
  userAgent      String?
  createdAt      DateTime     @default(now())
  actor          User         @relation("UserAuditLogs", fields: [actorId], references: [id], onDelete: Restrict)
  organization   Organization @relation("OrganizationAuditLogs", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([actorId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

// ============================================
// ENUMS
// ============================================

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
  EXPIRED
}

enum AuditAction {
  // Authentication
  USER_REGISTERED
  USER_LOGGED_IN
  USER_LOGGED_OUT
  TOKEN_REFRESHED

  // Organization
  ORGANIZATION_CREATED
  ORGANIZATION_UPDATED
  ORGANIZATION_SWITCHED

  // Membership
  MEMBERSHIP_CREATED
  MEMBERSHIP_ROLE_UPDATED
  MEMBERSHIP_REMOVED

  // Invitations
  INVITATION_CREATED
  INVITATION_ACCEPTED
  INVITATION_REVOKED
  INVITATION_DECLINED
  INVITATION_RESENT
  INVITATION_EXPIRED

  // Platform
  PLATFORM_CONNECTED
  PLATFORM_DISCONNECTED

  // Ad Accounts
  AD_ACCOUNT_CREATED
  AD_ACCOUNT_UPDATED
  AD_ACCOUNT_DELETED

  // Campaigns
  CAMPAIGN_CREATED
  CAMPAIGN_UPDATED
  CAMPAIGN_DELETED
  CAMPAIGN_ARCHIVED
  CAMPAIGN_RESTORED

  // Ad Sets
  AD_SET_CREATED
  AD_SET_UPDATED
  AD_SET_DELETED
  AD_SET_ARCHIVED
  AD_SET_RESTORED

  // Ads
  AD_CREATED
  AD_UPDATED
  AD_DELETED
  AD_ARCHIVED
  AD_RESTORED

  // Creatives
  CREATIVE_CREATED
  CREATIVE_UPDATED
  CREATIVE_DELETED
  CREATIVE_ARCHIVED
  CREATIVE_RESTORED

  // Creative Assets
  CREATIVE_ASSET_CREATED
  CREATIVE_ASSET_UPDATED
  CREATIVE_ASSET_DELETED
  CREATIVE_ASSET_ARCHIVED
  CREATIVE_ASSET_RESTORED
  CREATIVE_ASSET_PRIMARY_SET
  CREATIVE_ASSET_REORDERED

  // API Keys
  API_KEY_CREATED
  API_KEY_REVOKED
}

enum StorageProvider {
  LOCAL
  S3
  R2
  MINIO
}

enum AuditEntity {
  USER
  ORGANIZATION
  MEMBERSHIP
  INVITATION
  PLATFORM
  AD_ACCOUNT
  CAMPAIGN
  AD_SET
  AD
  CREATIVE
  CREATIVE_ASSET
  API_KEY
}
