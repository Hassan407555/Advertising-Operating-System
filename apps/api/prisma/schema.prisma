model PlatformConnection {
  id                   String           @id @default(cuid())
  organizationId       String
  createdByUserId      String
  platform             PlatformType
  accountId            String           @db.VarChar(255)
  accountName          String           @db.VarChar(255)
  externalName         String?          @db.VarChar(255)
  status               ConnectionStatus @default(ACTIVE)
  syncStatus           SyncStatus       @default(SYNCED)
  lastSyncedAt         DateTime?
  lastSuccessfulSyncAt DateTime?
  lastFailedSyncAt     DateTime?
  webhookSecret        String?
  webhookUrl           String?
  metadata             Json?
  deletedAt            DateTime?
  version              Int              @default(1)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User @relation("PlatformConnectionCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  credentials PlatformCredential[]
  adAccounts  AdAccount[]

  @@unique([organizationId, platform, accountId])
  @@index([organizationId, deletedAt])
  @@index([organizationId])
  @@index([platform])
  @@index([status])
  @@index([syncStatus])
  @@index([deletedAt])
}

model PlatformCredential {
  id                String           @id @default(cuid())
  platformConnectionId String
  accessToken       String           @db.Text // Encrypted
  refreshToken      String?          @db.Text // Encrypted
  expiresAt         DateTime?
  scopes            String[]         @db.VarChar(100)
  isActive          Boolean          @default(true)
  revokedAt         DateTime?
  revokedReason     String?          @db.VarChar(255)
  rotatedAt         DateTime?
  version           Int              @default(1)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  platformConnection PlatformConnection @relation(fields: [platformConnectionId], references: [id], onDelete: Cascade)

  @@index([platformConnectionId])
  @@index([isActive])
  @@index([expiresAt])
  @@index([revokedAt])
}

model AdAccount {
  id                    String           @id @default(cuid())
  organizationId        String
  platformConnectionId  String
  platform              PlatformType
  externalId            String           @db.VarChar(255)
  externalName          String?          @db.VarChar(255) // Renamed
  externalStatus        String?          @db.VarChar(50)  // Renamed
  accountName           String           @db.VarChar(255)
  accountNumber         String?          @db.VarChar(100)
  currency              Currency         @default(USD)
  timezone              String           @db.VarChar(50)
  status                AdAccountStatus  @default(ACTIVE)
  isActive              Boolean          @default(true)
  spend                 Decimal?         @db.Decimal(18, 2)
  impressions           Int?
  clicks                Int?
  conversions           Decimal?         @db.Decimal(18, 2)
  deletedAt             DateTime?
  lastSyncedAt          DateTime?
  lastSuccessfulSyncAt  DateTime?
  lastFailedSyncAt      DateTime?
  metadata              Json?
  version               Int              @default(1)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  organization          Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  platformConnection    PlatformConnection @relation(fields: [platformConnectionId], references: [id], onDelete: Restrict)
  campaigns             Campaign[]

  @@unique([organizationId, platformConnectionId, externalId])
  @@unique([platformConnectionId, externalId])
  @@index([organizationId, deletedAt])
  @@index([organizationId])
  @@index([platformConnectionId])
  @@index([platform])
  @@index([status])
  @@index([externalId])
  @@index([deletedAt])
  @@index([isActive])
}

model Campaign {
  id                    String                @id @default(cuid())
  organizationId        String                // RESTORED for fast tenant filtering
  adAccountId           String
  externalId            String                @db.VarChar(255)
  externalName          String?               @db.VarChar(255) // Renamed
  externalStatus        String?               @db.VarChar(50)  // Renamed
  name                  String                @db.VarChar(255)
  slug                  String?               @db.VarChar(100) // Optional for nice URLs
  objective             CampaignObjective
  status                CampaignStatus        @default(DRAFT)
  buyingType            CampaignBuyingType    @default(AUCTION)
  dailyBudget           Decimal?              @db.Decimal(18, 2)
  lifetimeBudget        Decimal?              @db.Decimal(18, 2)
  currency              Currency              @default(USD)
  startDate             DateTime?
  endDate               DateTime?
  isActive              Boolean               @default(true)
  spend                 Decimal?              @db.Decimal(18, 2)
  impressions           Int?
  clicks                Int?
  conversions           Decimal?              @db.Decimal(18, 2)
  deletedAt             DateTime?
  archivedAt            DateTime?             // Separate from status
  lastSyncedAt          DateTime?
  lastSuccessfulSyncAt  DateTime?
  lastFailedSyncAt      DateTime?
  metadata              Json?
  tags                  Json?                 // For flexible categorization
  version               Int                   @default(1)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  organization          Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  adAccount             AdAccount             @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  adSets                AdSet[]

  @@unique([organizationId, adAccountId, externalId])
  @@unique([adAccountId, externalId])
  @@unique([organizationId, slug]) // Optional if slugs are used
  @@index([organizationId, deletedAt])
  @@index([organizationId])
  @@index([adAccountId])
  @@index([status])
  @@index([objective])
  @@index([externalId])
  @@index([startDate])
  @@index([endDate])
  @@index([deletedAt])
  @@index([isActive])
  @@index([archivedAt])
}

model AdSet {
  id                    String                 @id @default(cuid())
  organizationId        String                 // RESTORED
  campaignId            String
  externalId            String                 @db.VarChar(255)
  externalName          String?                @db.VarChar(255) // Renamed
  externalStatus        String?                @db.VarChar(50)  // Renamed
  name                  String                 @db.VarChar(255)
  status                AdSetStatus            @default(DRAFT)
  dailyBudget           Decimal?               @db.Decimal(18, 2)
  lifetimeBudget        Decimal?               @db.Decimal(18, 2)
  bidAmount             Decimal?               @db.Decimal(18, 2)
  billingEvent          BillingEvent?
  targeting             Json?                  // Platform-specific targeting (will be normalized later)
  startDate             DateTime?
  endDate               DateTime?
  isActive              Boolean                @default(true)
  spend                 Decimal?               @db.Decimal(18, 2)
  impressions           Int?
  clicks                Int?
  conversions           Decimal?               @db.Decimal(18, 2)
  deletedAt             DateTime?
  archivedAt            DateTime?
  lastSyncedAt          DateTime?
  lastSuccessfulSyncAt  DateTime?
  lastFailedSyncAt      DateTime?
  metadata              Json?
  tags                  Json?
  version               Int                    @default(1)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign              Campaign               @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads                   Ad[]

  @@unique([organizationId, campaignId, externalId])
  @@unique([campaignId, externalId])
  @@index([organizationId, deletedAt])
  @@index([organizationId])
  @@index([campaignId])
  @@index([status])
  @@index([externalId])
  @@index([deletedAt])
  @@index([isActive])
  @@index([archivedAt])
}

model Ad {
  id                    String                 @id @default(cuid())
  organizationId        String                 // RESTORED
  adSetId               String
  creativeId            String?
  externalId            String                 @db.VarChar(255)
  externalName          String?                @db.VarChar(255) // Renamed
  externalStatus        String?                @db.VarChar(50)  // Renamed
  name                  String                 @db.VarChar(255)
  status                AdStatus               @default(DRAFT)
  isActive              Boolean                @default(true)
  spend                 Decimal?               @db.Decimal(18, 2)
  impressions           Int?
  clicks                Int?
  conversions           Decimal?               @db.Decimal(18, 2)
  deletedAt             DateTime?
  archivedAt            DateTime?
  lastSyncedAt          DateTime?
  lastSuccessfulSyncAt  DateTime?
  lastFailedSyncAt      DateTime?
  metadata              Json?
  tags                  Json?
  version               Int                    @default(1)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  adSet                 AdSet                  @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  creative              Creative?              @relation(fields: [creativeId], references: [id], onDelete: SetNull)
  assets                CreativeAsset[]

  @@unique([organizationId, adSetId, externalId])
  @@unique([adSetId, externalId])
  @@index([organizationId, deletedAt])
  @@index([organizationId])
  @@index([adSetId])
  @@index([status])
  @@index([externalId])
  @@index([deletedAt])
  @@index([isActive])
  @@index([archivedAt])
}

model Creative {
  id                    String                 @id @default(cuid())
  organizationId        String
  externalId            String?                @db.VarChar(255)
  externalName          String?                @db.VarChar(255) // Renamed
  name                  String                 @db.VarChar(255)
  type                  CreativeType
  headline              String?                @db.VarChar(255)
  primaryText           String?                @db.Text
  description           String?                @db.Text
  callToAction          CallToAction?
  landingPageUrl        String?                @db.VarChar(2000)
  deepLinkUrl           String?                @db.VarChar(2000)
  isActive              Boolean                @default(true)
  deletedAt             DateTime?
  archivedAt            DateTime?
  lastSyncedAt          DateTime?
  lastSuccessfulSyncAt  DateTime?
  lastFailedSyncAt      DateTime?
  metadata              Json?
  tags                  Json?
  version               Int                    @default(1)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ads                   Ad[]
  assets                CreativeAsset[]

  @@index([organizationId, deletedAt])
  @@index([organizationId])
  @@index([type])
  @@index([externalId])
  @@index([deletedAt])
  @@index([isActive])
  @@index([archivedAt])
}

model CreativeAsset {
  id               String              @id @default(cuid())

  organizationId   String
  creativeId       String?
  adId             String?

  assetType        CreativeAssetType

  storageProvider  StorageProvider     @default(LOCAL)

  fileName         String              @db.VarChar(255)
  originalFileName String              @db.VarChar(255)

  storageKey       String              @db.VarChar(1000)

  url              String              @db.VarChar(2000)
  thumbnailUrl     String?             @db.VarChar(2000)

  mimeType         String              @db.VarChar(255)
  extension        String              @db.VarChar(20)

  checksum         String?             @db.VarChar(128)

  width            Int?
  height           Int?

  fileSize         BigInt? @default(0)

  duration         Decimal? @db.Decimal(10, 3)

  displayOrder     Int                 @default(0)

  isPrimary        Boolean             @default(false)

  metadata         Json?

  deletedAt        DateTime?
  archivedAt       DateTime?

  version          Int                 @default(1)

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
creative     Creative?    @relation(fields: [creativeId], references: [id], onDelete: Cascade)
ad           Ad?          @relation(fields: [adId], references: [id], onDelete: Cascade)

@@index([organizationId])
@@index([organizationId, deletedAt])
@@index([organizationId, creativeId])
@@index([creativeId])
@@index([adId])
@@index([assetType])
@@index([storageProvider])
@@index([isPrimary])
@@index([displayOrder])
@@index([deletedAt])
@@index([archivedAt])
}

model ApiKey {
  id                String              @id @default(cuid())
  organizationId    String
  userId            String
  name              String              @db.VarChar(100)
  keyHash           String              @unique
  role              ApiKeyRole          @default(READ)
  permissions       Json?               // Flexible permissions
  lastUsedAt        DateTime?
  expiresAt         DateTime?
  isActive          Boolean             @default(true)
  deletedAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user              User                @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([organizationId, deletedAt])
  @@index([organizationId])
  @@index([userId])
  @@index([isActive])
  @@index([deletedAt])
  @@unique([organizationId, name, deletedAt])
}